void main() {
    int[] values = [1, 3];
    arrayInsert(values, 1, 2);
    arraySet(values, 2, 4);
    print(toString(arrayGet(values, 0)) + "," + toString(arrayGet(values, 1)) + "," + toString(arrayGet(values, 2)) + "\n");
    arrayRemove(values, 1);
    print(toString(count(values)) + "\n");
    print(toString(arrayPop(values)) + "\n");
    print(toString(arrayGet(values, 0)) + "\n");
}
