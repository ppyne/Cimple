int fib(int n) {
    if (n <= 0) { return 0; }
    if (n == 1) { return 1; }
    int a = 0;
    int b = 1;
    for (int i = 2; i <= n; i++) {
        int c = a + b;
        a = b;
        b = c;
    }
    return b;
}

void main(string[] args) {
    int limit = 10;
    if (count(args) > 0) {
        limit = toInt(args[0]);
    }
    for (int i = 0; i <= limit; i++) {
        print("fib(" + toString(i) + ") = " + toString(fib(i)) + "\n");
    }
}
