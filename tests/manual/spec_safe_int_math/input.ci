void main() {
    print(toString(safeDivInt(9, 3, -1)) + "\n");
    print(toString(safeDivInt(9, 0, -1)) + "\n");
    print(toString(safeModInt(9, 4, -1)) + "\n");
    print(toString(safeModInt(9, 0, -1)) + "\n");
    print(toString(minInt(2, 5)) + "\n");
    print(toString(maxInt(2, 5)) + "\n");
    print(toString(clampInt(12, 0, 10)) + "\n");
}
