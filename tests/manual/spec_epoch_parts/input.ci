void main() {
    int ts = makeEpoch(2025, 1, 2, 3, 4, 5);
    print(toString(epochToYear(ts)) + "\n");
    print(toString(epochToMonth(ts)) + "\n");
    print(toString(epochToDay(ts)) + "\n");
    print(toString(epochToHour(ts)) + "\n");
    print(toString(epochToMinute(ts)) + "\n");
    print(toString(epochToSecond(ts)) + "\n");
}
