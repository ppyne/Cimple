void main() {
    print(toString(isEven(4)) + "\n");
    print(toString(isOdd(5)) + "\n");
    print(toString(clampInt(12, 0, 10)) + "\n");
    print(toString(safeDivInt(7, 0, 99)) + "\n");
    print(toString(safeModInt(7, 0, 88)) + "\n");
    print(toString(approxEqual(0.1 + 0.2, 0.3, 0.0001)) + "\n");
    print(toString(isFinite(1.0)) + "\n");
}
