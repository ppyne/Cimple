void main() {
    print(toString(abs(-3.5)) + "\n");
    print(toString(min(2.0, 5.0)) + "\n");
    print(toString(max(2.0, 5.0)) + "\n");
    print(toString(floor(3.9)) + "\n");
    print(toString(ceil(3.1)) + "\n");
    print(toString(round(3.6)) + "\n");
    print(toString(trunc(-2.9)) + "\n");
    print(toString(fmod(7.5, 2.0)) + "\n");
    print(toString(sqrt(9.0)) + "\n");
    print(toString(pow(2.0, 3.0)) + "\n");
    print(toString(toInt(3.9)) + "\n");
    print(toString(toInt("12")) + "\n");
    print(toString(toFloat("2.5")) + "\n");
    print(toString(toBool("true")) + "\n");
    print(toString(isIntString("42")) + "\n");
    print(toString(isFloatString("1.5")) + "\n");
    print(toString(isBoolString("false")) + "\n");
}
