{
  "comments": {
    "lineComment": "//",
    "blockComment": ["/*", "*/"]
  },
  "brackets": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    { "open": "{", "close": "}" },
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open": "\"", "close": "\"", "notIn": ["string", "comment"] },
    { "open": "'", "close": "'", "notIn": ["string", "comment"] },
    { "open": "`", "close": "`", "notIn": ["string", "comment"] }
  ],
  "surroundingPairs": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["\"", "\""],
    ["'", "'"],
    ["`", "`"]
  ],
  "indentationRules": {
    "increaseIndentPattern": "^((?!.*\\/\\*).*\\{[^}\"'`]*|(?:.*\\*\\/)?)\\s*$",
    "decreaseIndentPattern": "^((?!.*\\{).*\\}|\\s*\\*\\/)\\s*$"
  },
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_]*",
  "onEnterRules": [
    {
      "beforeText": "^\\s*\\/\\*\\*(?!\\/)([^\\*]|\\*(?!\\/))*$",
      "afterText": "^\\s*\\*\\/$",
      "action": {
        "indent": "indentOutdent",
        "appendText": " * "
      }
    },
    {
      "beforeText": "^\\s*\\/\\*\\*(?!\\/)([^\\*]|\\*(?!\\/))*$",
      "action": {
        "indent": "indent",
        "appendText": " * "
      }
    },
    {
      "beforeText": "^\\s* \\*(?!\\/)([^\\*]|\\*(?!\\/))*$",
      "action": {
        "indent": "none",
        "appendText": "* "
      }
    },
    {
      "beforeText": "^\\s* \\*\\/\\s*$",
      "action": {
        "indent": "none",
        "removeText": 1
      }
    }
  ]
}
