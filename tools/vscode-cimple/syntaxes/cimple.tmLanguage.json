{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Cimple",
  "scopeName": "source.cimple",
  "fileTypes": ["ci"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#constants" },
    { "include": "#support_constants" },
    { "include": "#keywords_exception" },
    { "include": "#keywords_declaration" },
    { "include": "#keywords_control" },
    { "include": "#keywords_other" },
    { "include": "#storage_types" },
    { "include": "#support_classes" },
    { "include": "#support_functions" },
    { "include": "#structure_declaration" },
    { "include": "#union_declaration" },
    { "include": "#function_definition" },
    { "include": "#self_super_member" },
    { "include": "#operators" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.block.cimple",
          "begin": "/\\*",
          "end": "\\*/",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.comment.begin.cimple" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.comment.end.cimple" }
          }
        },
        {
          "name": "comment.line.double-slash.cimple",
          "begin": "//",
          "end": "$",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.comment.cimple" }
          }
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.triple.cimple",
          "begin": "\"\"\"",
          "end": "\"\"\"",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.string.begin.cimple" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.string.end.cimple" }
          },
          "patterns": [
            {
              "name": "constant.character.escape.cimple",
              "match": "\\\\(n|t|r|\\\\|\"|'|0|u[0-9a-fA-F]{4}|U[0-9a-fA-F]{8})"
            }
          ]
        },
        {
          "name": "string.quoted.double.cimple",
          "begin": "\"",
          "end": "\"",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.string.begin.cimple" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.string.end.cimple" }
          },
          "patterns": [
            {
              "name": "constant.character.escape.cimple",
              "match": "\\\\(n|t|r|\\\\|\"|'|0|u[0-9a-fA-F]{4}|U[0-9a-fA-F]{8})"
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.cimple",
          "match": "\\b[0-9]+\\.[0-9]+([eE][+-]?[0-9]+)?\\b"
        },
        {
          "name": "constant.numeric.float.exponent.cimple",
          "match": "\\b[0-9]+[eE][+-]?[0-9]+\\b"
        },
        {
          "name": "constant.numeric.hex.cimple",
          "match": "\\b0[xX][0-9a-fA-F]+\\b"
        },
        {
          "name": "constant.numeric.integer.cimple",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.cimple",
          "match": "\\b(true|false)\\b"
        }
      ]
    },
    "support_constants": {
      "patterns": [
        {
          "name": "support.constant.cimple",
          "match": "\\b(EOL|INT_MAX|INT_MIN|INT_SIZE|FLOAT_SIZE|FLOAT_DIG|FLOAT_EPSILON|FLOAT_MIN|FLOAT_MAX|M_PI|M_E|M_TAU|M_SQRT2|M_LN2|M_LN10|KEY_NONE|KEY_CHAR|KEY_ENTER|KEY_ESC|KEY_TAB|KEY_BACKSPACE|KEY_DELETE|KEY_UP|KEY_DOWN|KEY_LEFT|KEY_RIGHT|KEY_HOME|KEY_END|KEY_PAGE_UP|KEY_PAGE_DOWN|KEY_RESIZE|TERM_COLOR_DEFAULT|TERM_COLOR_BLACK|TERM_COLOR_RED|TERM_COLOR_GREEN|TERM_COLOR_YELLOW|TERM_COLOR_BLUE|TERM_COLOR_MAGENTA|TERM_COLOR_CYAN|TERM_COLOR_WHITE)\\b"
        }
      ]
    },
    "keywords_control": {
      "patterns": [
        {
          "name": "keyword.control.cimple",
          "match": "\\b(if|else|while|for|return|break|continue|in)\\b"
        }
      ]
    },
    "keywords_declaration": {
      "patterns": [
        {
          "name": "keyword.declaration.cimple",
          "match": "\\b(structure|union|import)\\b"
        }
      ]
    },
    "keywords_exception": {
      "patterns": [
        {
          "name": "keyword.control.exception.cimple",
          "match": "\\b(try|catch|finally|throw)\\b"
        }
      ]
    },
    "keywords_other": {
      "patterns": [
        {
          "name": "keyword.other.cimple",
          "match": "\\b(clone|self|super)\\b"
        }
      ]
    },
    "storage_types": {
      "patterns": [
        {
          "name": "storage.type.primitive.cimple",
          "match": "\\b(int|float|bool|string|byte|void)(?=\\s*(?:\\[\\]|\\[\\w+\\]|\\s))"
        },
        {
          "name": "storage.type.primitive.cimple",
          "match": "\\b(int|float|bool|string|byte|void)\\b"
        }
      ]
    },
    "support_classes": {
      "patterns": [
        {
          "name": "support.class.cimple",
          "match": "\\b(Exception|RuntimeException|IoException|RegExpException|ExecResult|RegExp|RegExpMatch|TerminalSize|KeyEvent)\\b"
        }
      ]
    },
    "support_functions": {
      "patterns": [
        {
          "name": "support.function.builtin.cimple",
          "match": "\\b(abs|absInt|acos|appendFile|appendFileBytes|approxEqual|arrayGet|arrayInsert|arrayPop|arrayPush|arrayRemove|arraySet|asin|assert|atan|atan2|basename|byteAt|bytesToFloat|bytesToInt|bytesToString|byteToInt|capitalize|ceil|chmod|clamp|clampInt|concat|contains|cos|count|countOccurrences|cwd|dirname|endsWith|epochToDay|epochToHour|epochToMinute|epochToMonth|epochToSecond|epochToYear|exec|execStatus|execStderr|execStdout|exit|exp|extension|fileExists|filename|floatToBytes|floor|fmod|format|formatDate|getEnv|glyphAt|glyphLen|indexOf|input|intToByte|intToBytes|isBlank|isBoolString|isDirectory|isEven|isExecutable|isFinite|isFloatString|isInfinite|isIntString|isNaN|isNegativeInfinity|isOdd|isPositiveInfinity|isReadable|isWritable|join|lastIndexOf|len|log|log2|log10|makeDir|makeDirAll|makeEpoch|mapClear|mapHas|mapKeys|mapRemove|mapSize|mapValues|max|maxInt|min|minInt|now|padLeft|padRight|pow|print|printErr|randFloat|randInt|readFile|readFileBytes|readLines|regexCompile|regexEnd|regexFind|regexFindAll|regexFlags|regexGroups|regexOk|regexPattern|regexReplace|regexReplaceAll|regexSplit|regexStart|regexTest|remove|repeat|replace|replaceAll|round|safeDivInt|safeModInt|sin|sleep|split|sqrt|startsWith|stringToBytes|substr|tan|tempPath|termBeep|termClear|termClearLine|termDisableRawMode|termEnableRawMode|termFlush|termGetSize|termHideCursor|termIsTTY|termMoveCursor|termPollKey|termReadKey|termResetStyle|termSetStyle|termShowCursor|termWriteAt|toBool|toFloat|toInt|toLower|toString|toUpper|trim|trimLeft|trimRight|trunc|writeFile|writeFileBytes|writeLines)\\b(?=\\s*\\()"
        }
      ]
    },
    "structure_declaration": {
      "patterns": [
        {
          "comment": "structure Foo : Bar { }",
          "name": "meta.structure.declaration.cimple",
          "match": "\\b(structure)\\s+([A-Za-z_][A-Za-z0-9_]*)(?:\\s*:\\s*([A-Za-z_][A-Za-z0-9_]*))?",
          "captures": {
            "1": { "name": "keyword.declaration.cimple" },
            "2": { "name": "entity.name.type.cimple" },
            "3": { "name": "entity.name.type.cimple" }
          }
        },
        {
          "comment": "union Foo { }",
          "name": "meta.union.declaration.cimple",
          "match": "\\b(union)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.cimple" },
            "2": { "name": "entity.name.type.cimple" }
          }
        }
      ]
    },
    "union_declaration": {
      "patterns": [
        {
          "name": "meta.union.declaration.cimple",
          "match": "\\b(union)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.cimple" },
            "2": { "name": "entity.name.type.cimple" }
          }
        }
      ]
    },
    "function_definition": {
      "patterns": [
        {
          "comment": "_init constructor method",
          "name": "meta.function.constructor.cimple",
          "match": "^\\s*void\\s+(_init)\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.function.constructor.cimple" }
          }
        },
        {
          "comment": "Function with primitive return type",
          "name": "meta.function.definition.cimple",
          "match": "^\\s*(void|int|float|bool|string|byte)(?:\\[\\])?\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "storage.type.primitive.cimple" },
            "2": { "name": "entity.name.function.cimple" }
          }
        },
        {
          "comment": "Function with user-defined struct return type (starts with uppercase)",
          "name": "meta.function.definition.cimple",
          "match": "^\\s*([A-Z][A-Za-z0-9_]*)(?:\\[\\])?\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.type.cimple" },
            "2": { "name": "entity.name.function.cimple" }
          }
        }
      ]
    },
    "self_super_member": {
      "patterns": [
        {
          "name": "meta.member-access.cimple",
          "match": "\\b(self|super)\\.([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.other.cimple" },
            "2": { "name": "variable.other.member.cimple" }
          }
        },
        {
          "name": "meta.member-access.cimple",
          "match": "([A-Za-z_][A-Za-z0-9_]*)\\.([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "variable.other.cimple" },
            "2": { "name": "variable.other.member.cimple" }
          }
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.cimple",
          "match": "(==|!=|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.logical.cimple",
          "match": "(&&|\\|\\||!)"
        },
        {
          "name": "keyword.operator.assignment.cimple",
          "match": "(?<![=!<>])=(?!=)"
        },
        {
          "name": "keyword.operator.arithmetic.cimple",
          "match": "(\\+\\+|--|\\+|-|\\*|/|%)"
        },
        {
          "name": "keyword.operator.ternary.cimple",
          "match": "\\?|(?<=\\s):"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.definition.block.begin.cimple",
          "match": "\\{"
        },
        {
          "name": "punctuation.definition.block.end.cimple",
          "match": "\\}"
        },
        {
          "name": "punctuation.definition.bracket.begin.cimple",
          "match": "\\["
        },
        {
          "name": "punctuation.definition.bracket.end.cimple",
          "match": "\\]"
        },
        {
          "name": "punctuation.definition.paren.begin.cimple",
          "match": "\\("
        },
        {
          "name": "punctuation.definition.paren.end.cimple",
          "match": "\\)"
        },
        {
          "name": "punctuation.terminator.statement.cimple",
          "match": ";"
        },
        {
          "name": "punctuation.separator.comma.cimple",
          "match": ","
        },
        {
          "name": "punctuation.accessor.cimple",
          "match": "\\."
        }
      ]
    }
  }
}
