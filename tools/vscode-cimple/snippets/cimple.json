{
  "Main function": {
    "prefix": "main",
    "body": [
      "void main() {",
      "\t$0",
      "}"
    ],
    "description": "Main entry point function"
  },
  "Function definition": {
    "prefix": "fn",
    "body": [
      "${1:void} ${2:functionName}(${3}) {",
      "\t$0",
      "}"
    ],
    "description": "Function definition"
  },
  "Structure definition": {
    "prefix": "structure",
    "body": [
      "structure ${1:Name} {",
      "\t$0",
      "}"
    ],
    "description": "Structure definition"
  },
  "Structure with inheritance": {
    "prefix": "structext",
    "body": [
      "structure ${1:Name} : ${2:Base} {",
      "\t$0",
      "}"
    ],
    "description": "Structure definition with inheritance"
  },
  "Union definition": {
    "prefix": "union",
    "body": [
      "union ${1:Name} {",
      "\t$0",
      "}"
    ],
    "description": "Union definition"
  },
  "For loop (C-style)": {
    "prefix": "for",
    "body": [
      "for (int ${1:i} = 0; ${1:i} < ${2:count}; ${1:i}++) {",
      "\t$0",
      "}"
    ],
    "description": "C-style for loop"
  },
  "For-in loop (array)": {
    "prefix": "forin",
    "body": [
      "for (${1:string} ${2:item} in ${3:collection}) {",
      "\t$0",
      "}"
    ],
    "description": "For-in loop over array"
  },
  "For-in loop (map)": {
    "prefix": "forinmap",
    "body": [
      "for (${1:string} ${2:key}, ${3:int} ${4:val} in ${5:map}) {",
      "\t$0",
      "}"
    ],
    "description": "For-in loop over map with key,value"
  },
  "While loop": {
    "prefix": "while",
    "body": [
      "while (${1:condition}) {",
      "\t$0",
      "}"
    ],
    "description": "While loop"
  },
  "If statement": {
    "prefix": "if",
    "body": [
      "if (${1:condition}) {",
      "\t$0",
      "}"
    ],
    "description": "If statement"
  },
  "If-else statement": {
    "prefix": "ifelse",
    "body": [
      "if (${1:condition}) {",
      "\t$2",
      "} else {",
      "\t$0",
      "}"
    ],
    "description": "If-else statement"
  },
  "Try-catch": {
    "prefix": "try",
    "body": [
      "try {",
      "\t$0",
      "} catch (${1:Exception} ${2:e}) {",
      "\t",
      "}"
    ],
    "description": "Try-catch block"
  },
  "Try-catch-finally": {
    "prefix": "trycf",
    "body": [
      "try {",
      "\t$0",
      "} catch (${1:Exception} ${2:e}) {",
      "\t",
      "} finally {",
      "\t",
      "}"
    ],
    "description": "Try-catch-finally block"
  },
  "Clone": {
    "prefix": "clone",
    "body": [
      "clone ${1:StructName}"
    ],
    "description": "Clone a structure instance"
  },
  "Clone with args": {
    "prefix": "cloneargs",
    "body": [
      "clone ${1:StructName}(${2})"
    ],
    "description": "Clone a structure instance with constructor arguments"
  },
  "Throw exception": {
    "prefix": "throw",
    "body": [
      "throw clone ${1:RuntimeException}(\"${2:message}\");"
    ],
    "description": "Throw a new exception"
  },
  "Print": {
    "prefix": "print",
    "body": [
      "print(${1:\"message\"});"
    ],
    "description": "Print to stdout"
  },
  "Print with format": {
    "prefix": "printf",
    "body": [
      "print(format(\"${1}\", ${2}));"
    ],
    "description": "Print formatted string"
  },
  "_init constructor": {
    "prefix": "_init",
    "body": [
      "void _init(${1}) {",
      "\t$0",
      "}"
    ],
    "description": "Structure constructor (_init method)"
  },
  "Variable declaration": {
    "prefix": "var",
    "body": [
      "${1:int} ${2:name} = ${3:value};"
    ],
    "description": "Variable declaration"
  },
  "Array declaration": {
    "prefix": "arr",
    "body": [
      "${1:int}[] ${2:name} = [${3}];"
    ],
    "description": "Array declaration"
  },
  "Map declaration": {
    "prefix": "map",
    "body": [
      "${1:int}[${2:string}] ${3:name} = [${4}];"
    ],
    "description": "Map declaration"
  },
  "Import": {
    "prefix": "import",
    "body": [
      "import \"${1:path}\";"
    ],
    "description": "Import a file"
  },
  "Assert": {
    "prefix": "assert",
    "body": [
      "assert(${1:condition}, \"${2:message}\");"
    ],
    "description": "Assert with message"
  }
}
